---
import Base from "../../layouts/Base.astro";
import { campaigns, getCampaign } from "../../data/campaigns";

export function getStaticPaths() {
  return campaigns.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const campaign = getCampaign(slug!);
if (!campaign) {
  return Astro.redirect("/404");
}

const statusLabel: Record<typeof campaign.status, string> = {
  active: "Active campaign",
  upcoming: "Upcoming campaign",
  resolved: "Resolved campaign",
};

// Base.astro appends " — Terms of Power", so pass only the campaign name.
const title = campaign.target.name;
const description = campaign.summary;
---

<Base title={title} description={description}>
  <!-- ─────────────── HERO ─────────────── -->
  <section id="top" class="section camp-hero">
    <div class="wrap">
      <p class="eyebrow">
        <span class={`status status--${campaign.status}`}
          >{statusLabel[campaign.status]}</span
        >
      </p>
      <h1 class="camp-hero__title">{campaign.target.name}</h1>
      <p class="lede camp-hero__lede">{campaign.summary}</p>

      <dl class="camp-meta">
        <div>
          <dt>The target</dt>
          <dd>
            {campaign.target.descriptor}{" "}
            <a
              href={campaign.target.url}
              rel="noopener noreferrer"
              target="_blank">{new URL(campaign.target.url).host}</a
            >
          </dd>
        </div>
        <div>
          <dt>Window</dt>
          <dd>
            <time datetime={campaign.startedOn.iso}
              >{campaign.startedOn.display}</time
            >
            {" → "}
            <time datetime={campaign.deadline.iso}
              >{campaign.deadline.display}</time
            >
          </dd>
        </div>
      </dl>

      <div class="btn-row">
        <a href="#participate" class="btn btn--primary btn--lg"
          >How to take part →</a
        >
        <a
          href={campaign.source.url}
          rel="noopener noreferrer"
          target="_blank"
          class="btn btn--secondary btn--lg">Read the policy</a
        >
      </div>
    </div>
  </section>

  <!-- ─────────────── THE CONTRADICTION ─────────────── -->
  <section class="section section--line section--muted">
    <div class="wrap">
      <p class="eyebrow"><span>The contradiction</span></p>
      <div class="contrast">
        <article class="contrast__col">
          <p class="contrast__label">What they say</p>
          <blockquote class="contrast__quote">
            “{campaign.brandPromise.quote}”
          </blockquote>
          <p class="fineprint">
            <a
              href={campaign.brandPromise.source}
              rel="noopener noreferrer"
              target="_blank">Hinge Health, on its own privacy page</a
            >
          </p>
        </article>
        <article class="contrast__col">
          <p class="contrast__label">What their terms enforce</p>
          <blockquote class="contrast__quote">
            Third parties may track your use of a health service across the web
            and apps — conduct the policy itself says may be a “sale” or
            “sharing” of your data.
          </blockquote>
          <p class="fineprint">
            <a
              href={campaign.source.url}
              rel="noopener noreferrer"
              target="_blank">{campaign.source.label}</a
            >
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ─────────────── THE CLAUSES ─────────────── -->
  <section id="clauses" class="section">
    <div class="wrap">
      <p class="eyebrow"><span>The clauses</span></p>
      <h2 class="h1 camp-h2">Quoted directly. Nothing paraphrased.</h2>
      <p class="lede camp-section-lede">
        Every line below is taken verbatim from {campaign.target.name}’s privacy
        policy. Read them in context at the{" "}
        <a href={campaign.source.url} rel="noopener noreferrer" target="_blank"
          >source</a
        >.
      </p>

      <div class="clauses">
        {
          campaign.clauses.map((c) => (
            <article class="card clause">
              <p class="clause__cat">{c.category}</p>
              <blockquote class="clause__quote">“{c.quote}”</blockquote>
              <p class="clause__why">{c.why}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────────── THE ASK ─────────────── -->
  <section class="section section--line section--muted">
    <div class="wrap">
      <p class="eyebrow"><span>What we’re asking for</span></p>
      <div class="asks">
        {
          campaign.asks.map((a) => (
            <article class="ask">
              <h3 class="ask__title">{a.title}</h3>
              <p class="ask__detail">{a.detail}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────────── PARTICIPATE ─────────────── -->
  <section id="participate" class="section section--line">
    <div class="wrap">
      <p class="eyebrow"><span>How to take part</span></p>
      <h2 class="h1 camp-h2" style="max-width:24ch">
        Send one message. In your own words.
      </h2>
      <p class="lede camp-section-lede">
        Reach {campaign.target.name} directly and tell them, plainly, why these terms
        matter to you. We don’t hand out a script on purpose — a hundred identical
        emails get filed as one complaint; a hundred genuine ones can’t be.
      </p>

      <div class="participate">
        <div class="participate__channels">
          <p class="participate__heading">Where to send it</p>
          <ul class="channels">
            {
              campaign.participate.channels.map((ch) => (
                <li class="channel">
                  <span class="channel__label">{ch.label}</span>
                  <a class="channel__value" href={ch.href}>
                    {ch.value}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="participate__points">
          <p class="participate__heading">What to cover</p>
          <ul class="points">
            {campaign.participate.talkingPoints.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────── NOTIFY / BACK ─────────────── -->
  <section class="section section--line section--muted">
    <div class="wrap camp-foot">
      <div>
        <h2 class="h2">Want the next one?</h2>
        <p class="lede" style="margin-top:8px">
          Leave your email and we’ll tell you when a new campaign opens —
          nothing else.
        </p>
      </div>
      <div class="btn-row">
        <a href="/#get-involved" class="btn btn--primary btn--lg"
          >Get notified →</a
        >
        <a href="/" class="btn btn--secondary btn--lg">Back to Terms of Power</a
        >
      </div>
    </div>
  </section>
</Base>

<style>
  .camp-hero {
    padding-bottom: var(--section-y-sm);
  }
  .camp-hero__title {
    font-size: clamp(40px, 6vw, 60px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .camp-hero__lede {
    max-width: 64ch;
    margin-top: 20px;
  }

  .status {
    font-size: 13px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
  }

  .camp-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-5);
    margin: 36px 0 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
  }
  .camp-meta dt {
    font-size: 13px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .camp-meta dd {
    margin: 0;
    color: var(--muted-foreground);
    max-width: 56ch;
  }

  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 36px;
  }

  .camp-h2 {
    margin-bottom: 12px;
  }
  .camp-section-lede {
    max-width: 64ch;
    margin-bottom: 40px;
  }

  /* Contradiction */
  .contrast {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-top: 8px;
  }
  .contrast__col {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--card-padding);
  }
  .contrast__label {
    font-size: 13px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--muted-foreground);
    margin: 0 0 14px;
  }
  .contrast__quote {
    margin: 0 0 16px;
    font-size: var(--text-h4);
    line-height: 1.45;
    color: var(--foreground);
  }

  /* Clauses */
  .clauses {
    display: grid;
    gap: var(--space-5);
  }
  .clause {
    padding: var(--card-padding);
  }
  .clause:hover {
    transform: none;
    box-shadow: none;
  }
  .clause__cat {
    font-size: 13px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 14px;
  }
  .clause__quote {
    margin: 0;
    padding-left: 18px;
    border-left: 2px solid var(--border);
    font-family: var(--font-mono);
    font-size: 15px;
    line-height: 1.65;
    color: var(--foreground);
  }
  .clause__why {
    margin: 16px 0 0;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  /* Asks */
  .asks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-top: 8px;
    counter-reset: ask;
  }
  .ask {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--card-padding);
  }
  .ask__title {
    font-size: var(--text-h4);
    line-height: 1.3;
    margin: 0 0 8px;
  }
  .ask__detail {
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  /* Participate */
  .participate {
    display: grid;
    grid-template-columns: minmax(0, 320px) 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  .participate__heading {
    font-size: 13px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 16px;
  }
  .channels {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .channel {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
  }
  .channel__label {
    display: block;
    font-size: var(--text-small);
    color: var(--muted-foreground);
    margin-bottom: 4px;
  }
  .channel__value {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: var(--weight-medium);
  }
  .points {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 14px;
  }
  .points li {
    position: relative;
    padding-left: 26px;
    line-height: 1.6;
    color: var(--foreground);
  }
  .points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--accent);
  }

  /* Footer band */
  .camp-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }
  .camp-foot .btn-row {
    margin-top: 0;
  }

  @media (max-width: 860px) {
    .contrast,
    .asks,
    .participate {
      grid-template-columns: 1fr;
    }
  }
</style>
