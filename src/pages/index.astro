---
import Base from "../layouts/Base.astro";
import { activeCampaign } from "../data/campaigns";

const active = activeCampaign();

const principles = [
  {
    t: "Behavior as raw material",
    d: "Everything you do is logged, packaged, and resold. Your activity is the product the service was built to harvest.",
  },
  {
    t: "Consent that isn’t a choice",
    d: "Agreement is broad, implicit, and forced. Accept everything, or don’t use the service at all.",
  },
  {
    t: "Protection without enforcement",
    d: "Privacy promises live on the marketing page. The terms that actually bind you live somewhere else entirely.",
  },
];

const steps = [
  {
    n: "1",
    t: "Identify",
    d: "Mid-sized brands with strong customer-facing identities and a clear gap between message and practice.",
  },
  {
    n: "2",
    t: "Audit",
    d: "Pinpoint specific, defensible clauses — geolocation sharing, model-training consent, indefinite retention.",
  },
  {
    n: "3",
    t: "Write",
    d: "Participants send structured messages as real customers, citing the terms and naming the tradeoff.",
  },
  {
    n: "4",
    t: "Make visible",
    d: "Pair private outreach with controlled public exposure. Not outrage — a visible contradiction.",
  },
  {
    n: "5",
    t: "Iterate",
    d: "Reinforce real improvements. Where there are none, expand participation and visibility.",
  },
];

const success = [
  "A company removes or narrows a clause after public scrutiny.",
  "Terms become a visible part of brand accountability.",
  "People recognize that coordinated action can move policy.",
];

const isItems = [
  "A coordinated pressure strategy",
  "Focused on specific, defensible clauses",
  "Built on clarity, visibility, and collective action",
  "Operated from within existing infrastructure",
];

const isNotItems = [
  "A general privacy awareness campaign",
  "A legal reform initiative",
  "A boycott or exit movement",
  "Targeted at individuals or employees",
];

const ways = [
  {
    t: "Join a campaign",
    d: "Add your name to an active effort. You’ll get one clear, structured action to take — no spam, no spectacle.",
  },
  {
    t: "Submit a clause",
    d: "Found extractive language in terms you’ve accepted? Send it in. Specific clauses become the next target.",
  },
  {
    t: "Spread the contradiction",
    d: "Share the gap between a brand’s promise and its contract. Visibility is the pressure.",
  },
];
---

<Base>
  <!-- ─────────────── HERO ─────────────── -->
  <section id="top" class="section hero">
    <div class="wrap">
      <p class="eyebrow reveal">
        <span>A coordinated accountability project</span>
      </p>
      <h1 class="hero__title reveal" style="animation-delay:70ms">
        Terms are not neutral. They are expressions of <span class="accent"
          >power.</span
        >
      </h1>
      <p class="lede reveal hero__lede" style="animation-delay:140ms">
        Most digital products run on terms you can’t read, can’t negotiate, and
        never actually agreed to. Terms of Power makes that imbalance visible,
        specific, and reputationally costly.
      </p>
      <div class="btn-row reveal" style="animation-delay:210ms">
        <a href="#method" class="btn btn--primary btn--lg">How it works →</a>
        <a href="#scope" class="btn btn--secondary btn--lg">What this is</a>
      </div>
    </div>
  </section>

  <!-- ─────────────── THE GAP ─────────────── -->
  <section id="the-gap" class="section section--line">
    <div class="wrap">
      <p class="eyebrow"><span>The gap we work in</span></p>
      <h2 class="h2" style="max-width:36ch;margin-bottom:40px">
        What a company says, and what its terms enforce, are rarely the same
        document.
      </h2>
      <div class="grid-2">
        <div class="panel">
          <div class="panel__label">What the brand says</div>
          <p class="panel__quote">
            “We respect your privacy. You’re in control.”
          </p>
        </div>
        <div class="panel">
          <div class="panel__label">What the terms enforce</div>
          <p class="panel__terms">
            …may collect precise geolocation, share data with third-party
            partners, use your content to train models, and retain records
            indefinitely.
          </p>
        </div>
      </div>
      <p class="lede gap__note">
        Most consumer products run on policies that are hard to read, impossible
        to negotiate, and disconnected from how the company describes itself. We
        treat those terms not as legal formalities, but as <strong
          >instruments of power</strong
        > that shape the relationship between people and organizations.
      </p>
    </div>
  </section>

  <!-- ─────────────── CORE PROBLEM ─────────────── -->
  <section id="problem" class="section section--muted">
    <div class="wrap">
      <p class="eyebrow"><span>The core problem</span></p>
      <h2 class="h2" style="max-width:32ch;margin-bottom:40px">
        Data extraction, by default.
      </h2>
      <div class="grid-3">
        {
          principles.map((p) => (
            <article class="card">
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </article>
          ))
        }
      </div>
      <p class="lede" style="max-width:74ch;margin-top:36px">
        Individual users have little leverage. Large platforms resist change.
        Mid-sized companies inherit terms from systems they don’t fully control
        — and that is exactly where pressure works.
      </p>
    </div>
  </section>

  <!-- ─────────────── THE METHOD ─────────────── -->
  <section id="method" class="section section--line">
    <div class="wrap">
      <p class="eyebrow"><span>The method</span></p>
      <h2 class="h2" style="max-width:36ch">
        Five steps, applied from within the system.
      </h2>
      <p class="lede" style="max-width:70ch;margin-top:20px">
        Not a boycott. Not a legal campaign. A coordinated pressure strategy
        built on clarity, visibility, and collective action.
      </p>
      <div class="rows">
        {
          steps.map((s) => (
            <div class="row-step">
              <div class="step__n">{s.n}</div>
              <div>
                <h3 class="row__h" style="margin-bottom:6px">
                  {s.t}
                </h3>
                <p class="row__d" style="max-width:64ch">
                  {s.d}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────────── GET INVOLVED ─────────────── -->
  <section id="get-involved" class="section section--line">
    <div class="wrap">
      <p class="eyebrow"><span>Get involved</span></p>
      <h2 class="h1" style="max-width:24ch;margin-bottom:16px">
        There’s a campaign running right now.
      </h2>
      <p class="lede" style="max-width:66ch;margin-bottom:40px">
        Collective action, kept simple. One live target, one clear thing to do —
        in your own words, no spam, no spectacle.
      </p>

      {
        active && (
          <a
            href={`/campaign/${active.slug}`}
            class="active-campaign"
            aria-label={`Active campaign: ${active.target.name} — see the campaign and take part`}
          >
            <div class="active-campaign__head">
              <span class="status-pill">Active campaign</span>
              <span class="active-campaign__deadline">
                Open through {active.deadline.display}
              </span>
            </div>
            <h3 class="active-campaign__title">{active.target.name}</h3>
            <p class="active-campaign__summary">{active.summary}</p>
            <span class="active-campaign__cta">
              See the campaign and take part →
            </span>
          </a>
        )
      }

      <div class="notify">
        <h3 class="notify__title">
          Not ready to act? Hear about the next one.
        </h3>
        <p class="notify__lede">
          Leave your email and we’ll tell you when a new campaign opens —
          nothing else.
        </p>

        <div id="join-done" class="join-done" hidden>
          Thank you — you’re on the list. We’ll reach out when a new campaign
          opens.
        </div>

        <form id="join-form" class="form-row" novalidate>
          <div class="form-row__field">
            <label for="email" class="sr-only">Email address</label>
            <input
              id="email"
              class="input"
              type="email"
              name="email"
              placeholder="you@company.com"
              autocomplete="email"
              required
            />
          </div>
          <button type="submit" class="btn btn--primary btn--md"
            >Notify me</button
          >
        </form>
        <p id="join-error" class="form-error" role="alert" hidden></p>
        <p class="form-note">
          We’ll only contact you about new campaigns. No lists, no resale —
          that would rather defeat the point.
        </p>
      </div>

      <div class="grid-3" style="margin-top:56px">
        {
          ways.map((w) => (
            <article class="card">
              <h3>{w.t}</h3>
              <p>{w.d}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────────── WHAT SUCCESS LOOKS LIKE ─────────────── -->
  <section id="success" class="section section--muted">
    <div class="wrap">
      <p class="eyebrow"><span>What success looks like</span></p>
      <h2 class="h2" style="max-width:34ch;margin-bottom:44px">
        What changes when it works.
      </h2>
      <div class="grid-3">
        {
          success.map((t) => (
            <div class="win">
              <p>{t}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────────── SCOPE / WHAT THIS IS ─────────────── -->
  <section id="scope" class="section">
    <div class="wrap">
      <p class="eyebrow"><span>Scope &amp; boundaries</span></p>
      <h2 class="h1" style="max-width:30ch;margin-bottom:16px">
        What this is — and isn’t.
      </h2>
      <p class="lede" style="max-width:68ch;margin-bottom:48px">
        Terms are expressions of power in the user–company relationship. Here is
        exactly how far we take that — and where we stop.
      </p>
      <div class="scope-cols">
        <div>
          <div class="col-label col-label--is">What it is</div>
          <ul class="checklist">
            {
              isItems.map((item) => (
                <li>
                  <>
                    <span class="checklist__mark">→</span>
                    <span>{item}</span>
                  </>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <div class="col-label">What it is not</div>
          <ul class="checklist checklist--not">
            {
              isNotItems.map((item) => (
                <li>
                  <>
                    <span class="checklist__x">×</span>
                    <span class="struck">{item}</span>
                  </>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
      <div class="position">
        <h3 class="h2" style="max-width:14ch">A position on infrastructure</h3>
        <div>
          <p class="lede" style="margin-bottom:16px">
            Terms of Power operates within existing internet infrastructure. It
            does not withdraw from or boycott platforms, and it asks for no
            ideological alignment from anyone.
          </p>
          <p class="lede">
            Instead, it applies pressure <strong>from within the system</strong> —
            on the belief that change is most effective when contradictions are made
            visible where they already exist.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────── DARK CONVICTION BAND ─────────────── -->
  <section class="section band-dark">
    <div class="wrap">
      <p class="eyebrow eyebrow--dark"><span>Our conviction</span></p>
      <h2 class="band-dark__title">
        Change is most effective when contradictions are made visible where they
        already exist.
      </h2>
      <div class="btn-row">
        {
          active ? (
            <a href={`/campaign/${active.slug}`} class="btn btn--primary btn--lg">
              Join the {active.target.name} campaign →
            </a>
          ) : (
            <a href="#get-involved" class="btn btn--primary btn--lg">
              Get involved →
            </a>
          )
        }
        <a href="#scope" class="btn btn--secondary btn--lg">What this is</a>
      </div>
    </div>
  </section>

  <!-- ─────────────── SIGNATURE STATEMENT ─────────────── -->
  <section class="section section--line">
    <div class="wrap">
      <div class="signature">
        <span class="signature__a">“This is what your brand says.</span><br />
        <span class="signature__b">This is what your terms enforce.”</span>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("join-form") as HTMLFormElement | null;
  const done = document.getElementById("join-done");
  const errorEl = document.getElementById("join-error");
  const input = document.getElementById("email") as HTMLInputElement | null;
  const submitBtn = form?.querySelector(
    "button[type=submit]",
  ) as HTMLButtonElement | null;

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.removeAttribute("hidden");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl?.setAttribute("hidden", "");

    const email = input?.value.trim() ?? "";
    if (!email || !/.+@.+\..+/.test(email)) {
      input?.focus();
      showError("Please enter a valid email address.");
      return;
    }

    submitBtn?.setAttribute("disabled", "");
    try {
      const res = await fetch("/api/notify", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ email }),
      });
      const data = (await res.json().catch(() => ({}))) as {
        ok?: boolean;
        error?: string;
      };

      if (!res.ok || !data.ok) {
        showError(data.error ?? "Something went wrong. Please try again.");
        submitBtn?.removeAttribute("disabled");
        return;
      }

      form.setAttribute("hidden", "");
      document.querySelector(".form-note")?.setAttribute("hidden", "");
      done?.removeAttribute("hidden");
    } catch {
      showError("Couldn’t reach the server. Please try again.");
      submitBtn?.removeAttribute("disabled");
    }
  });
</script>

<style>
  /* Hero */
  .hero {
    padding-top: var(--section-y);
    padding-bottom: var(--section-y-sm);
  }
  .hero__title {
    font-size: clamp(40px, 6vw, 60px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    max-width: 17ch;
    margin: 0;
  }
  .hero__lede {
    max-width: 54ch;
    margin-top: 24px;
  }
  .btn-row {
    display: flex;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  /* Heading sizes (token-driven) */
  .h2 {
    font-size: var(--text-h2);
    line-height: 1.2;
  }
  .h1 {
    font-size: var(--text-h1);
    line-height: 1.12;
  }

  /* Generic grids */
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* The gap — static panels (no hover) */
  .panel {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--card-padding);
  }
  .panel__label {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    margin-bottom: 16px;
  }
  .panel__quote {
    font-size: 22px;
    line-height: 1.4;
    color: var(--foreground);
    margin: 0;
    font-weight: 500;
  }
  .panel__terms {
    font-family: var(--font-mono);
    font-size: 15px;
    line-height: 1.7;
    color: var(--foreground);
    margin: 0;
  }
  .gap__note {
    max-width: 72ch;
    margin-top: 40px;
  }

  .textlink {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .textlink:hover {
    color: var(--accent-hover);
  }

  /* Rows (why / method) */
  .rows {
    margin-top: 44px;
    border-top: 1px solid var(--border);
  }
  .row-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
  }
  .row__h {
    font-size: var(--text-h4);
    margin: 0;
    line-height: 1.3;
  }
  .row__d {
    color: var(--muted-foreground);
    margin: 0;
    line-height: 1.7;
  }
  .step__n {
    font-family: var(--font-mono);
    font-size: 26px;
    color: var(--accent);
    font-weight: 600;
    line-height: 1;
  }

  /* Success */
  .win {
    border-top: 2px solid var(--accent);
    padding-top: 20px;
  }
  .win p {
    font-size: var(--text-body-lg);
    color: var(--foreground);
    margin: 0;
    line-height: 1.5;
    max-width: 32ch;
  }

  /* Scope */
  .scope-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .col-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted-foreground);
    margin-bottom: 20px;
  }
  .col-label--is {
    color: var(--accent);
  }
  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .checklist li {
    display: flex;
    gap: 14px;
    align-items: baseline;
    font-size: var(--text-body-lg);
    color: var(--foreground);
  }
  .checklist--not li {
    color: var(--muted-foreground);
  }
  .checklist__mark {
    color: var(--accent);
    font-weight: 600;
  }
  .struck {
    text-decoration: line-through;
  }
  .position {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  /* Dark band */
  .band-dark {
    background: var(--muted-foreground);
    color: #fff;
  }
  .band-dark__title {
    color: #fff;
    font-size: clamp(30px, 4.2vw, 44px);
    line-height: 1.18;
    letter-spacing: -0.02em;
    max-width: 20ch;
    margin: 0;
  }
  .eyebrow--dark > span {
    color: rgba(255, 255, 255, 0.65);
  }
  .band-dark .btn--secondary:hover {
    background: var(--surface-muted);
  }

  /* Get involved — active campaign card (primary) */
  .active-campaign {
    display: block;
    background: var(--surface-card);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: var(--card-padding);
    max-width: 760px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }
  .active-campaign:hover {
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .active-campaign__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--surface-accent-soft);
    padding: 5px 12px;
    border-radius: var(--radius-pill);
  }
  .status-pill::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }
  .active-campaign__deadline {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted-foreground);
  }
  .active-campaign__title {
    font-size: var(--text-h3);
    line-height: 1.2;
    margin: 0 0 10px;
  }
  .active-campaign__summary {
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0 0 18px;
    max-width: 64ch;
  }
  .active-campaign__cta {
    display: inline-block;
    font-weight: 600;
    color: var(--accent);
  }
  .active-campaign:hover .active-campaign__cta {
    color: var(--accent-hover);
  }

  /* Notify (secondary) */
  .notify {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .notify__title {
    font-size: var(--text-h4);
    line-height: 1.3;
    margin: 0 0 8px;
  }
  .notify__lede {
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0 0 24px;
    max-width: 56ch;
  }
  .form-error {
    font-size: var(--text-small);
    color: var(--accent);
    font-weight: 500;
    margin: 12px 0 0;
    max-width: 56ch;
  }

  /* Get involved */
  .form-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: flex-end;
    max-width: 560px;
  }
  .form-row__field {
    flex: 1;
    min-width: 240px;
  }
  .form-note {
    font-size: var(--text-small);
    color: var(--muted-foreground);
    margin: 12px 0 0;
    max-width: 56ch;
  }
  .join-done {
    background: var(--surface-accent-soft);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    max-width: 560px;
    color: var(--accent);
    font-weight: 600;
    font-size: var(--text-body-lg);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* Signature */
  .signature {
    font-size: clamp(34px, 4vw, 46px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 600;
  }
  .signature__a {
    color: var(--foreground);
  }
  .signature__b {
    color: var(--accent);
  }

  /* Responsive */
  @media (max-width: 760px) {
    .grid-2,
    .grid-3,
    .scope-cols,
    .position {
      grid-template-columns: 1fr;
    }
    .position {
      margin-top: 48px;
      padding-top: 36px;
      gap: 24px;
    }
  }
</style>
