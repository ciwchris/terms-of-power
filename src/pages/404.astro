---
import Base from '../layouts/Base.astro';
---

<Base title="Not found" description="That page doesn’t exist.">
  <section class="section" style="min-height:50vh">
    <div class="wrap">
      <p class="eyebrow"><span>404</span></p>
      <h1 class="h1" style="margin-bottom:16px">This page doesn’t exist.</h1>
      <p class="lede" style="max-width:48ch;margin-bottom:32px">
        The page you’re looking for may have moved, or never existed.
      </p>
      <a href="/" class="btn btn--primary btn--lg">Back to Terms of Power</a>
    </div>
  </section>
</Base>
