---
// SiteHeader — sticky, translucent off-white with backdrop blur.
// Anchors are root-relative (/#…) so they work from campaign pages too, not
// just the homepage where the target sections live.
const links = [
  { href: "/#method", label: "How it works" },
  { href: "/#scope", label: "What this is" },
];
---

<header class="hdr">
  <div class="wrap hdr__inner">
    <a href="/#top" class="brand" aria-label="Terms of Power — home">
      <img
        src="/tp-mark.svg"
        alt="Terms of Power logo"
        height="32"
        width="32"
        aria-hidden="true"
      />
      <span class="brand__name">Terms of <span>Power</span></span>
    </a>

    <input
      type="checkbox"
      id="nav-toggle"
      class="hdr__toggle"
      aria-label="Toggle navigation"
    />
    <label for="nav-toggle" class="hdr__burger" aria-hidden="true"
      ><span></span></label
    >

    <nav class="hdr__nav" aria-label="Primary">
      {
        links.map((l) => (
          <a href={l.href} class="hdr__link">
            {l.label}
          </a>
        ))
      }
      <a href="/#get-involved" class="btn btn--primary btn--md hdr__cta"
        >Get involved</a
      >
    </nav>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface-page) 80%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding-inline: var(--space-5);
    gap: var(--space-4);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__rule {
    width: 10px;
    height: 22px;
    background: var(--accent);
    border-radius: 2px;
    display: inline-block;
  }
  .brand__name {
    font-weight: var(--weight-semibold);
    font-size: 18px;
    color: var(--foreground);
    letter-spacing: -0.01em;
  }
  .brand__name span {
    color: var(--accent);
  }

  .hdr__nav {
    display: flex;
    align-items: center;
    gap: var(--space-7);
  }
  .hdr__link {
    font-size: var(--text-small);
    color: var(--muted-foreground);
    text-decoration: none;
  }
  .hdr__link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .hdr__cta {
    margin-left: var(--space-2);
  }

  .hdr__toggle,
  .hdr__burger {
    display: none;
  }

  @media (max-width: 800px) {
    .hdr__nav {
      gap: var(--space-5);
    }
    .hdr__link {
      display: none;
    }
    .hdr__cta {
      display: none;
    }

    .hdr__burger {
      display: block;
      width: 26px;
      height: 18px;
      position: relative;
      cursor: pointer;
    }
    .hdr__burger span,
    .hdr__burger span::before,
    .hdr__burger span::after {
      content: "";
      position: absolute;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--foreground);
      transition:
        transform 0.2s ease,
        opacity 0.2s ease;
    }
    .hdr__burger span {
      top: 8px;
    }
    .hdr__burger span::before {
      top: -7px;
    }
    .hdr__burger span::after {
      top: 7px;
    }

    .hdr__nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--surface-page);
      border-bottom: 1px solid var(--border);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .hdr__toggle:checked ~ .hdr__nav {
      max-height: 70vh;
    }
    .hdr__toggle:checked ~ .hdr__burger span {
      background: transparent;
    }
    .hdr__toggle:checked ~ .hdr__burger span::before {
      transform: translateY(7px) rotate(45deg);
    }
    .hdr__toggle:checked ~ .hdr__burger span::after {
      transform: translateY(-7px) rotate(-45deg);
    }

    .hdr__toggle:checked ~ .hdr__nav .hdr__link {
      display: block;
      padding: 16px var(--space-5);
      border-top: 1px solid var(--border);
    }
    .hdr__toggle:checked ~ .hdr__nav .hdr__cta {
      display: inline-flex;
      margin: 16px var(--space-5);
    }
  }
</style>
